# ============================
# Python / バックエンド
# ============================

# 仮想環境（uv が作るフォルダ）
# → 依存パッケージが全部入っているが、pyproject.toml から再生成できる
backend/.venv/

# Pythonのキャッシュファイル（自動生成される一時ファイル）
__pycache__/
*.py[cod]
*.pyo

# データベースファイル（個人データが入るので絶対にGit管理しない）
*.db
*.sqlite
*.sqlite3

# 仮名化マッピングファイル（個人情報が含まれるので絶対にGit管理しない）
*pseudonym_mapping*.json

# ============================
# 環境変数ファイル（最重要！）
# ============================
# APIキーやパスワードが書かれているファイル
# → 絶対にGitHubにアップしてはいけない
.env
.env.local
.env.*.local
.env.production

# ============================
# Node.js / フロントエンド
# ============================

# 依存パッケージ（package.json から再インストールできる）
node_modules/

# Next.js のビルド成果物（自動生成される）
frontend/.next/
frontend/out/

# ============================
# OS・エディタが作るゴミファイル
# ============================
.DS_Store          # macOS が作る隠しファイル
Thumbs.db          # Windows が作るサムネイルファイル
*.swp              # Vim の一時ファイル
.vscode/           # VSCode の設定（個人設定なので共有しない）

# ============================
# Docker / デプロイ
# ============================

# PostgreSQLのデータ（個人データが入るので絶対にGit管理しない）
pgdata/

# ============================
# 個人メモ
# ============================
interview-notes/
